# ─── OpenAI ───────────────────────────────────────────
# REMPLACE PAR TA NOUVELLE CLÉ (après avoir révoqué l'ancienne)
OPENAI_API_KEY=COLLE_TA_NOUVELLE_CLE_ICI

# ─── Supabase ─────────────────────────────────────────
# À remplir après création du compte supabase.com
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────
# À remplir après création du compte stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (emails) ──────────────────────────────────
# À remplir après création du compte resend.com
RESEND_API_KEY=

# ─── URL de ton site ──────────────────────────────────
SITE_URL=https://lorinizi.com
