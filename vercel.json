{
  "functions": {
    "api/generate-images.js":  { "maxDuration": 60 },
    "api/generate-story.js":   { "maxDuration": 60 },
    "api/stripe-webhook.js":   { "maxDuration": 60 },
    "api/generate-pdf.js":     { "maxDuration": 60 },
    "api/submit-order.js":     { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/creer", "destination": "/creer.html" },
    { "source": "/confirmation", "destination": "/confirmation.html" }
  ]
}
